      },
      {
        type: "Article",
        citation:
          "George W. Downs, David M. Rocke, and Peter N. Barsoom, 'Is the Good News about Compliance Good News about Cooperation?' (1996) 50 International Organization 379.",
        note:
          "Important critique of selection effects and the interpretation of high compliance rates in international regimes.",
        url: "https://www.cambridge.org/core/journals/international-organization/article/is-the-good-news-about-compliance-good-news-about-cooperation/636DE333F8E1EC944825DDBFD81BE294",
      },
      {
        type: "Article",
        citation:
          "Beth A. Simmons, 'Compliance with International Agreements' (1998) 1 Annual Review of Political Science 75.",
        note:
          "Review article on why states comply with international agreements and how compliance should be studied.",
        url: "https://www.annualreviews.org/content/journals/10.1146/annurev.polisci.1.1.75",
      },
    ],
  },
  {
    title: "International law and international relations",
    description:
      "Works that explicitly join legal analysis with IR theory, institutional design, compliance research, domestic politics, and empirical study.",
    items: [
      {
        type: "Book",
        citation:
          "Jeffrey L. Dunoff and Mark A. Pollack, eds., Interdisciplinary Perspectives on International Law and International Relations: The State of the Art (Cambridge University Press, 2013).",
        note:
