---
import SiteLayout from "../../layouts/SiteLayout.astro";
import RecordCard from "../../components/RecordCard.astro";
import { loadSiteContent } from "../../lib/content.mjs";
import { getTopicProfile } from "../../lib/search.mjs";
import { guides } from "../../lib/guides.mjs";

export function getStaticPaths() {
  return guides.map((guide) => ({ params: { slug: guide.slug }, props: { guide } }));
}

const { guide } = Astro.props;
const content = loadSiteContent();
const profile = getTopicProfile(content, guide.slug);
const featured = guide.featuredIds
  .map((id) => content.records.find((record) => record.id === id))
  .filter(Boolean);
const readings = guide.readingIds
  .map((id) => content.bibliography.find((entry) => entry.id === id))
  .filter(Boolean);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const withBase = (path) => `${base}${path}`;
---

<SiteLayout title={`${guide.title} | China, International Law, and International Order`}>
  <section class="page-intro page-intro--topic">
    <p class="eyebrow">{guide.eyebrow}</p>
    <h1>{guide.title}</h1>
    <p>{guide.dek}</p>
  </section>

  <section class="dossier">
    <aside class="dossier__aside">
      <h2>Key questions</h2>
      <ol>
        {guide.questions.map((question) => <li>{question}</li>)}
      </ol>
      <a class="button button--primary" href={withBase(`/archive/?topic=${guide.slug}`)}>Search this topic</a>
    </aside>
    <div class="dossier__main">
      <h2>Analytical frame</h2>
      <p>{guide.thesis}</p>

      <h2>Featured documents and practice</h2>
      <div class="record-stack">
        {featured.map((record) => <RecordCard record={record} />)}
      </div>

      <h2>Chronology signals</h2>
      <div class="timeline-list">
        {profile.timeline.slice(0, 6).map((entry) => (
          <article>
            <time datetime={entry.date}>{entry.date}</time>
            <h3>{entry.title}</h3>
            <p>{entry.summary}</p>
          </article>
        ))}
      </div>

      <h2>Selected readings</h2>
      <div class="reading-list">
        {readings.map((entry) => (
          <article>
            <h3><a href={entry.url} target="_blank" rel="noreferrer">{entry.title}</a></h3>
            <p>{entry.citation}</p>
            <small>{entry.note}</small>
          </article>
        ))}
      </div>
    </div>
  </section>
</SiteLayout>
